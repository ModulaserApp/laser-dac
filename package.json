{
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": "16.x",
    "yarn": "1.x"
  },
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "devDependencies": {
    "@types/node": "^14.17.4",
    "husky": "^6.0.0",
    "lerna": "^4.0.0",
    "prettier": "^2.3.2",
    "pretty-quick": "^3.1.1",
    "typescript": "^4.3.4"
  },
  "resolutions": {
    "node-gyp": "10.2.0",
    "node-gyp/**/isexe": "3.1.1"
  },
  "scripts": {
    "publish": "lerna publish",
    "build": "lerna run build",
    "test": "lerna run test",
    "watch": "lerna run --parallel watch"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  }
}
